# ─────────────────────────────────────────────────────────────
# Club Innogeeks — Environment Variables
#
# In Replit: add these via the "Secrets" tab (left sidebar 🔒)
# On another platform: copy this to .env and fill in values
# NEVER commit .env to git — it's in .gitignore
# ─────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────
# From: https://supabase.com/dashboard → Project → Settings → API

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# From: Settings → Database → Connection string (URI)
SUPABASE_DB_URL=postgresql://postgres:PASSWORD@db.your-project-ref.supabase.co:5432/postgres

# Connection pooler (used by drizzle-kit push)
# From: Settings → Database → Connection pooler
SUPABASE_DB_HOST=aws-0-ap-south-1.pooler.supabase.com
SUPABASE_DB_PORT=5432
SUPABASE_DB_USER=postgres.your-project-ref
SUPABASE_DB_NAME=postgres
SUPABASE_DB_PASSWORD=your-db-password

# ── Session ───────────────────────────────────────────────────
SESSION_SECRET=generate-a-long-random-string-here

# ── Razorpay ──────────────────────────────────────────────────
# From: https://dashboard.razorpay.com → Settings → API Keys
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=your-razorpay-secret
# From: Settings → Webhooks → Secret
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret

# ── Cloudinary ────────────────────────────────────────────────
# From: https://cloudinary.com/console → Dashboard
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ── Express server ────────────────────────────────────────────
# PORT is auto-set by Replit; set manually on other platforms
PORT=5000
NODE_ENV=development

# CORS — comma-separated allowed origins for the quiz website
# Example: https://quiz.innogeeks.in,http://localhost:5173
# Leave empty in development (allows all); REQUIRED in production
ALLOWED_ORIGINS=
